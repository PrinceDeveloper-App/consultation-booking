# Application Environment (development, testing, production)
CI_ENV=development

# Base URL (change to match your local server)
# For PHP built-in server: http://localhost:8000/
# For XAMPP: https://localhost/ikic.ca/
BASE_URL=http://localhost:8000/

# Database Configuration
DB_HOSTNAME=localhost
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=ikic_db
DB_DRIVER=mysqli

# Stripe API Keys (use test keys for development)
STRIPE_API_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_CURRENCY=cad

# Stripe Payment Amount (in dollars)
STRIPE_PAYMENT_AMOUNT=86.62

# SMTP Email Configuration
SMTP_HOST=mail.ikic.ca
SMTP_PORT=465
SMTP_USER=isha@ikic.ca
SMTP_PASS=your_smtp_password
SMTP_CRYPTO=ssl
EMAIL_FROM=isha@ikic.ca
EMAIL_FROM_NAME=Isha Kapoor Immigration Consulting Inc.

# Google Maps API Key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Cron Authentication Token
CRON_AUTH_TOKEN=your_random_cron_token_here

# Encryption Key (generate a random 32-char string)
ENCRYPTION_KEY=your_random_encryption_key_here
